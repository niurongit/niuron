# PostgreSQL / Neon connection string used by Drizzle.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Required for Express session signing and proof-service key derivation.
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-at-least-32-random-bytes"

# Optional: override server port. Defaults to 5000.
PORT=5000
